# API Configuration
API_BASE_URL=http://api.psb.local:8080/api
API_TIMEOUT=30000

# Environment
ENVIRONMENT=development
DEBUG_MODE=true

# Security
ENCRYPTION_KEY=PSB_DIGITAL_SECURE_2026
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Firebase Configuration (Optional)
FIREBASE_PROJECT_ID=psb-digital-app
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_APP_ID=your-firebase-app-id

# Analytics
ANALYTICS_ENABLED=true
CRASH_REPORTING_ENABLED=true

# Feature Flags
ENABLE_BIOMETRIC_LOGIN=true
ENABLE_FACE_ID=true
ENABLE_FINGERPRINT=true
ENABLE_SSL_PINNING=true
ENABLE_DEVICE_VERIFICATION=true

# Rate Limiting
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_TIMEOUT=300
MAX_OTP_ATTEMPTS=5
OTP_TIMEOUT=600

# Token Configuration
ACCESS_TOKEN_EXPIRY=900000
REFRESH_TOKEN_EXPIRY=2592000000
SESSION_TIMEOUT=1800000

# API Endpoints
OTP_SEND_ENDPOINT=/auth/send-otp
OTP_VERIFY_ENDPOINT=/auth/verify-otp
LOGIN_ENDPOINT=/auth/login
REGISTER_ENDPOINT=/auth/register
REFRESH_TOKEN_ENDPOINT=/auth/refresh-token

# Logging
LOG_LEVEL=INFO
ENABLE_API_LOGGING=true
ENABLE_SECURITY_LOGGING=true

# Development Options
MOCK_API_RESPONSES=false
SKIP_SSL_VERIFICATION=false
